PREFIX cwork:<http://www.bbc.co.uk/ontologies/creativework/>
# SPB advanced q21 (faceted search) — full-text word in the title, pinned
# category/audience, and the official `cwork:tag ?tag` requirement folded to the
# about/mentions topic links the SPB generator actually emits (no literal
# cwork:tag exists). Set of work uris.
SELECT DISTINCT ?cw WHERE {
  ?cw a cwork:CreativeWork ; cwork:title ?title ;
      cwork:category <{{CATEGORY}}> ; cwork:audience <{{AUDIENCE}}> .
  { ?cw cwork:about ?tag } UNION { ?cw cwork:mentions ?tag }
  FILTER(regex(?title, "\\b{{WORD}}\\b", "i"))
}
